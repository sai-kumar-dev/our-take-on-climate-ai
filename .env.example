# Copy this file to `.env` and fill in the values you want to use locally.

# Optional: enable Groq layman explanations in the UI.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: point to a specific trained artifact directory.
# MODEL_ARTIFACT_DIR=C:\path\to\our_take_on_climate_ai\artifacts\data_new_training

# Optional: sign feedback records for tamper detection.
# FEEDBACK_SIGNING_SECRET=replace_with_a_long_random_secret

# Optional: override the UI-to-API base URL when running outside the default local setup.
# API_BASE_URL=http://127.0.0.1:8000
