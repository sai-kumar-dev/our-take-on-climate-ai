{
  "mode": "production",
  "sanity_mode": "strict",
  "data": {
    "dataset_path": "data/sample_dataset.csv",
    "time_column": "time",
    "region_column": "region_key",
    "sample_weight_column": "data_confidence",
    "categorical_features": [
      "N_class",
      "P_class",
      "K_class",
      "fertility_class"
    ],
    "critical_columns": [
      "region_key",
      "time",
      "temp_avg",
      "rain_total",
      "humidity_avg",
      "max_temp",
      "pH",
      "N",
      "P",
      "K",
      "soil_health_index",
      "irrigation_index",
      "rotation_score",
      "geo_confidence",
      "data_confidence"
    ]
  },
  "split": {
    "test_periods": 2,
    "validation_periods": 1,
    "min_train_periods": 6,
    "fallback_test_fraction": 0.2,
    "fallback_validation_fraction": 0.1
  },
  "model": {
    "backend": "xgboost",
    "allow_backend_fallback": false,
    "random_state": 42,
    "early_stopping_rounds": 50,
    "xgboost_params": {
      "n_estimators": 800,
      "learning_rate": 0.03,
      "max_depth": 6,
      "min_child_weight": 2,
      "subsample": 0.85,
      "colsample_bytree": 0.85,
      "reg_alpha": 0.0,
      "reg_lambda": 1.5,
      "tree_method": "hist",
      "n_jobs": 1,
      "verbosity": 0,
      "objective": "reg:squarederror",
      "eval_metric": "rmse"
    }
  },
  "calibration": {
    "enabled": true,
    "method": "temperature_scaling",
    "preferred_split": "validation",
    "temperature_grid": [0.5, 0.75, 1.0, 1.25, 1.5, 2.0, 3.0]
  },
  "evaluation": {
    "top_k": 3,
    "stability_sample_size": 512,
    "stability_noise_fraction": 0.03,
    "top_feature_count": 12
  },
  "inference": {
    "drift_zscore_threshold": 3.0,
    "warmup_enabled": true,
    "warmup_explainer_count": 2,
    "required_features": [
      "temp_avg",
      "rain_total",
      "humidity_avg",
      "max_temp",
      "pH",
      "N",
      "P",
      "K",
      "N_class",
      "P_class",
      "K_class",
      "fertility_class"
    ]
  },
  "sanity_checks": {
    "water_intensive_crops": [
      "rice"
    ],
    "heat_sensitive_crops": [
      "rice",
      "onion",
      "grapes"
    ]
  },
  "artifacts": {
    "output_dir": "artifacts/training"
  }
}
