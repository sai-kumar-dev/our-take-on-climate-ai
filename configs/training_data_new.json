{
  "mode": "production",
  "sanity_mode": "warn",
  "data": {
    "dataset_path": "data/processed/data_new_final_ml_dataset.csv"
  },
  "split": {
    "test_periods": 6,
    "validation_periods": 6,
    "min_train_periods": 18
  },
  "model": {
    "backend": "xgboost",
    "allow_backend_fallback": false,
    "random_state": 42,
    "xgboost_params": {
      "n_estimators": 120,
      "learning_rate": 0.08,
      "max_depth": 4,
      "min_child_weight": 2,
      "subsample": 0.9,
      "colsample_bytree": 0.9,
      "reg_alpha": 0.0,
      "reg_lambda": 1.0,
      "tree_method": "hist",
      "n_jobs": 2,
      "verbosity": 0,
      "objective": "reg:squarederror",
      "eval_metric": "rmse"
    }
  },
  "calibration": {
    "enabled": true,
    "method": "temperature_scaling",
    "preferred_split": "validation",
    "temperature_grid": [0.5, 0.75, 1.0, 1.25, 1.5, 2.0, 3.0]
  },
  "inference": {
    "drift_zscore_threshold": 3.0,
    "warmup_enabled": true,
    "warmup_explainer_count": 2,
    "required_features": [
      "temp_avg",
      "rain_total",
      "humidity_avg",
      "max_temp",
      "pH",
      "N",
      "P",
      "K",
      "N_class",
      "P_class",
      "K_class",
      "fertility_class"
    ]
  },
  "sanity_checks": {
    "demo_rule_blend_weight": 0.0,
    "water_intensive_crops": ["sugarcane", "banana", "coconut"],
    "heat_sensitive_crops": ["potato", "onion", "black pepper", "cardamom", "wheat"],
    "base_row_strategy": "scenario_responsive_test_row",
    "scenarios": {
      "reduced_rainfall": {
        "feature_multipliers": {
          "rain_total": 0.7,
          "rain_lag_14": 0.7,
          "humidity_avg": 0.95
        },
        "target_group": "water_intensive_crops",
        "expected_direction": "decrease",
        "min_group_delta": 0.007
      },
      "increased_irrigation": {
        "feature_additions": {
          "irrigation_index": 0.25
        },
        "target_group": "water_intensive_crops",
        "expected_direction": "increase",
        "min_group_delta": 0.0035
      },
      "extreme_heat": {
        "feature_additions": {
          "temp_avg": 4.0,
          "max_temp": 5.0,
          "max_temp_3d": 5.0
        },
        "target_group": "heat_sensitive_crops",
        "expected_direction": "decrease",
        "min_group_delta": 0.01
      }
    }
  },
  "artifacts": {
    "output_dir": "artifacts/data_new_training"
  }
}
